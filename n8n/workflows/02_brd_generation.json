  "connections": {
    "Webhook Trigger": {"main": [[{"node": "PostgreSQL", "type": "main", "index": 0}]]},
    "PostgreSQL": {"main": [[{"node": "IF", "type": "main", "index": 0}]]},
    "IF": {"main": [[{"node": "SplitInBatches", "type": "main", "index": 0}], [{"node": "NoOp", "type": "main", "index": 0}]]},
    "SplitInBatches": {"main": [[{"node": "HTTP Request Gemini Analyst", "type": "main", "index": 0}]]},
    "HTTP Request Gemini Analyst": {"main": [[{"node": "Code Node: Parse", "type": "main", "index": 0}]]}
