    { "id": "4", "name": "NoOp", "type": "n8n-nodes-base.noOp", "typeVersion": 1, "position": [600,100], "parameters": {} },
    { "id": "5", "name": "SplitInBatches", "type": "n8n-nodes-base.splitInBatches", "typeVersion": 1, "position": [600,-100], "parameters": {"batchSize": 1} },
    { "id": "6", "name": "HTTP Request Gemini Analyst", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.1, "position": [800,-100], "parameters": {"method": "POST", "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={{$env.GEMINI_API_KEY}}"} },
    { "id": "7", "name": "Code Node: Parse", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1000,-100], "parameters": {"jsCode": "return [{json: {}}];"} }
