{
  "name": "AutoFlow - 02 BRD Generation",
  "nodes": [
    { "id": "1", "name": "Webhook Trigger", "type": "n8n-nodes-base.webhook", "typeVersion": 1, "position": [0,0], "parameters": {"path": "generate-brds", "httpMethod": "POST"} },
    { "id": "2", "name": "PostgreSQL", "type": "n8n-nodes-base.postgres", "typeVersion": 2.2, "position": [200,0], "parameters": {"operation": "executeQuery", "query": "SELECT * FROM feedback_clusters WHERE processed = false ORDER BY mention_count DESC"} },
